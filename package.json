{
  "name": "upgrade-optimizer",
  "version": "0.1.0",
  "main": "public/electron.js",
  "homepage": "https://uocraW.github.io/coc-upgrade-optimizer",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "clsx": "^2.1.1",
    "dhtmlx-gantt": "^9.0.14",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-scripts": "5.0.1",
    "ts-ortools": "^0.0.20",
    "vis-timeline": "^8.3.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "concurrently npm:dev:react npm:dev:electron",
    "dev:react": "react-scripts start",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build:web": "react-scripts build",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages -d build",
    "start": "react-scripts start",
    "build": "react-scripts build && electron-builder",
    "dist": "npm run build && npx electron-builder --publish=never",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^24.13.3",
    "electron-is-dev": "^2.0.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "wait-on": "^7.2.0"
  }
}
